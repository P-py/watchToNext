{
  "info": {
    "name": "watchToNext — Recommender API",
    "description": "Generic request templates for the recommender endpoints. One request per operation — fill in `userId`, `movieId`, `limit` via collection variables (or override at request time).\n\nBase path `/api` is applied globally by the server (`WebMvcConfig`), so `baseUrl` already includes it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "userId",  "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "movieId", "value": "1", "type": "string", "description": "movies.id (local PK)" },
    { "key": "rating",  "value": "4.5", "type": "string" },
    { "key": "limit",   "value": "20", "type": "string" },
    { "key": "q",       "value": "matrix", "type": "string" },
    { "key": "page",    "value": "1", "type": "string" },
    { "key": "size",    "value": "20", "type": "string" }
  ],
  "item": [
    {
      "name": "Rate movie (upsert)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"rating\": {{rating}} }" },
        "url": {
          "raw": "{{baseUrl}}/ratings/{{movieId}}?userId={{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["ratings", "{{movieId}}"],
          "query": [{ "key": "userId", "value": "{{userId}}" }]
        }
      }
    },
    {
      "name": "Unrate movie",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/ratings/{{movieId}}?userId={{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["ratings", "{{movieId}}"],
          "query": [{ "key": "userId", "value": "{{userId}}" }]
        }
      }
    },
    {
      "name": "Favorite movie",
      "request": {
        "method": "PUT",
        "url": {
          "raw": "{{baseUrl}}/favorites/{{movieId}}?userId={{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["favorites", "{{movieId}}"],
          "query": [{ "key": "userId", "value": "{{userId}}" }]
        }
      }
    },
    {
      "name": "Unfavorite movie",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/favorites/{{movieId}}?userId={{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["favorites", "{{movieId}}"],
          "query": [{ "key": "userId", "value": "{{userId}}" }]
        }
      }
    },
    {
      "name": "Get movie by id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["movies", "{{movieId}}"]
        }
      }
    },
    {
      "name": "Search movies by title",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/movies?q={{q}}&limit={{limit}}",
          "host": ["{{baseUrl}}"],
          "path": ["movies"],
          "query": [
            { "key": "q", "value": "{{q}}" },
            { "key": "limit", "value": "{{limit}}" }
          ]
        }
      }
    },
    {
      "name": "List popular movies",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/movies/popular?page={{page}}&size={{size}}",
          "host": ["{{baseUrl}}"],
          "path": ["movies", "popular"],
          "query": [
            { "key": "page", "value": "{{page}}" },
            { "key": "size", "value": "{{size}}" }
          ]
        }
      }
    },
    {
      "name": "Get recommendations",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/recommendations?userId={{userId}}&limit={{limit}}",
          "host": ["{{baseUrl}}"],
          "path": ["recommendations"],
          "query": [
            { "key": "userId", "value": "{{userId}}" },
            { "key": "limit",  "value": "{{limit}}" }
          ]
        }
      }
    }
  ]
}
