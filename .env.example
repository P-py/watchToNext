# PostgreSQL
POSTGRES_DB=watchtonext
POSTGRES_USER=watchtonext
POSTGRES_PASSWORD=watchtonext
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Spring Boot (used by ./gradlew :api:dbSetup and bootRun)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/watchtonext
SPRING_DATASOURCE_USERNAME=watchtonext
SPRING_DATASOURCE_PASSWORD=watchtonext
REDIS_URL=redis://localhost:6379
