# Base URL of the API, including the global /api prefix.
# Required in production builds; defaults to this value in development.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# When true, all services return mock data and never hit the API.
# Useful while the backend is unavailable.
NEXT_PUBLIC_USE_MOCKS=true

# When "false", the top-of-page academic-project banner is hidden.
# Any other value (or unset) keeps it shown. Defaults to shown.
NEXT_PUBLIC_SHOW_ACADEMIC_DISCLAIMER=true
