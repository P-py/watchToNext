# ---- Client-side -----------------------------------------------------------
# When true, all services return mock data and never hit the API.
# Useful while the backend is unavailable.
NEXT_PUBLIC_USE_MOCKS=true

# When "false", the top-of-page academic-project banner is hidden.
# Any other value (or unset) keeps it shown. Defaults to shown.
NEXT_PUBLIC_SHOW_ACADEMIC_DISCLAIMER=true

# Keycloak (auth provider). Read both server-side (route handlers) and
# safely public — used only to derive redirect URLs to the IdP.
NEXT_PUBLIC_KEYCLOAK_BASE_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=watchtonext
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=watchtonext-frontend
NEXT_PUBLIC_AUTH_REDIRECT_URI=http://localhost:3000

# ---- Server-only -----------------------------------------------------------
# Upstream Spring Boot API. Reached by /api/proxy/* route handlers, never
# by the browser. Must NOT have the NEXT_PUBLIC_ prefix.
API_UPSTREAM_URL=http://localhost:8080/api

# Keycloak JWKS endpoint — used by lib/auth/session to verify access-token
# signatures. Must NOT have the NEXT_PUBLIC_ prefix.
KEYCLOAK_JWKS_URL=http://localhost:8180/realms/watchtonext/protocol/openid-connect/certs

# Sets the `Secure` flag on auth cookies. Leave false for localhost HTTP dev;
# set "true" in any environment served over HTTPS.
AUTH_COOKIE_SECURE=false

# Session store. The BFF stores token bundles in a dedicated Redis instance
# keyed by an opaque session id (the only thing in the browser cookie).
AUTH_REDIS_URL=redis://:changeme@localhost:6380

# Absolute upper bound for a session, regardless of refresh-token rotation.
# After this many seconds the session is destroyed even if tokens are still valid.
SESSION_MAX_LIFESPAN_SECONDS=36000

# AES-256-GCM key (32 bytes, base64). Encrypts every session payload before it
# reaches Redis — separates "access to Redis" from "ability to read tokens".
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotate in staging/prod. Keep out of the same secret store as AUTH_REDIS_URL
# when possible (defense in depth).
SESSION_ENCRYPTION_KEY=replace-me-with-32-bytes-base64
