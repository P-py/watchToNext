{
  "info": {
    "name": "watchToNext — Recommender API",
    "description": "Generic request templates for the recommender endpoints. One request per operation — fill in `userId`, `movieId`, `limit` via collection variables (or override at request time).\n\nBase path `/api` is applied globally by the server (`WebMvcConfig`), so `baseUrl` already includes it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "movieId",
      "value": "1",
      "type": "string",
      "description": "movies.id (local PK)"
    },
    {
      "key": "rating",
      "value": "4.5",
      "type": "string"
    },
    {
      "key": "limit",
      "value": "20",
      "type": "string"
    },
    {
      "key": "q",
      "value": "matrix",
      "type": "string"
    },
    {
      "key": "page",
      "value": "1",
      "type": "string"
    },
    {
      "key": "size",
      "value": "20",
      "type": "string"
    },
    {
      "key": "keycloakBaseUrl",
      "value": "http://localhost:8180",
      "type": "string"
    },
    {
      "key": "keycloakRealm",
      "value": "watchtonext",
      "type": "string"
    },
    {
      "key": "keycloakAdminUser",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "keycloakAdminPassword",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "keycloakAdminToken",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the 'Get admin token' request via a test script."
    },
    {
      "key": "keycloakUserId",
      "value": "",
      "type": "string",
      "description": "Paste the UUID of the user you want to inspect (from 'List users')."
    },
    {
      "key": "keycloakSearchUsername",
      "value": "",
      "type": "string",
      "description": "Username (or email, since registrationEmailAsUsername=true) to look up."
    },
    {
      "key": "bffProxyUrl",
      "value": "http://localhost:3000/api/proxy",
      "type": "string",
      "description": "Next BFF proxy. All API requests go through here so the proxy attaches Bearer from the session cookie."
    },
    {
      "key": "wtnSession",
      "value": "",
      "type": "string",
      "description": "Opaque session id. Login at http://localhost:3000/api/auth/login, then DevTools → Application → Cookies → `wtn_session` → copy value here."
    },
    {
      "key": "genreId",
      "value": "28",
      "type": "string",
      "description": "genres.id (e.g. 28 = Action)"
    },
    {
      "key": "movieIds",
      "value": "1,2,3",
      "type": "string",
      "description": "Comma-separated movies.id list for /recommendations/from"
    }
  ],
  "item": [
    {
      "name": "Rating status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "wtn_session={{wtnSession}}"
          }
        ],
        "url": {
          "raw": "{{bffProxyUrl}}/ratings/{{movieId}}",
          "host": [
            "{{bffProxyUrl}}"
          ],
          "path": [
            "ratings",
            "{{movieId}}"
          ]
        },
        "description": "Authenticated. Returns { rating: number | null } — the caller's rating for the movie, or null when not rated."
      },
      "response": []
    },
    {
      "name": "Rate movie (upsert)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "wtn_session={{wtnSession}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": {{rating}}\n}"
        },
        "url": {
          "raw": "{{bffProxyUrl}}/ratings/{{movieId}}",
          "host": [
            "{{bffProxyUrl}}"
          ],
          "path": [
            "ratings",
            "{{movieId}}"
          ]
        },
        "description": "Authenticated. User comes from the session JWT — no userId param."
      }
    },
    {
