{
  "realm": "watchtonext",
  "displayName": "watchToNext",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername and notEmail and passwordHistory(3)",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "eventsEnabled": true,
  "eventsExpiration": 1209600,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "internationalizationEnabled": false,
  "supportedLocales": [],
  "defaultLocale": "en",
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Default role granted to every newly registered user.",
        "composite": false,
        "clientRole": false,
        "containerId": "watchtonext"
      },
      {
        "name": "ADMIN",
        "description": "Elevated privileges for administrative operations.",
        "composite": false,
        "clientRole": false,
        "containerId": "watchtonext"
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false,
        "clientRole": false,
        "containerId": "watchtonext"
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false,
        "containerId": "watchtonext"
      },
      {
        "name": "default-roles-watchtonext",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": ["USER", "offline_access", "uma_authorization"]
        },
        "clientRole": false,
        "containerId": "watchtonext"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-watchtonext",
    "description": "${role_default-roles}",
    "composite": true,
    "clientRole": false,
    "containerId": "watchtonext"
  },
  "clients": [
    {
      "clientId": "watchtonext-frontend",
      "name": "watchToNext SPA (public)",
      "description": "Public OIDC client used by the Next.js frontend. Authorization Code + PKCE (S256) only.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": false,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "adminUrl": "http://localhost:3000",
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+",
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "client.session.idle.timeout": "1800",
        "client.session.max.lifespan": "36000",
        "use.refresh.tokens": "true",
        "client_credentials.use_refresh_token": "false",
        "tls.client.certificate.bound.access.tokens": "false",
        "require.pushed.authorization.requests": "false"
      }
    },
    {
      "clientId": "watchtonext-api",
      "name": "watchToNext API (resource server)",
      "description": "Bearer-only client used by the Spring Boot backend to validate JWTs.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "frontchannelLogout": false,
      "fullScopeAllowed": false,
      "secret": "dev-only-change-me",
      "redirectUris": [],
      "webOrigins": [],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "client_credentials.use_refresh_token": "false",
        "tls.client.certificate.bound.access.tokens": "false"
      }
    }
  ],
  "clientScopes": [],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{}}},{\"name\":\"email\",\"required\":{\"roles\":[\"user\"]},\"validations\":{\"email\":{},\"length\":{\"max\":320}}},{\"name\":\"firstName\",\"required\":{\"roles\":[\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}},{\"name\":\"lastName\",\"required\":{\"roles\":[\"user\"]},\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}}}]}"
          ]
        }
      }
    ]
  },
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "referrerPolicy": "no-referrer",
    "xRobotsTag": "none",
    "xFrameOptions": "DENY",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "smtpServer": {},
  "loginTheme": "keycloak",
  "accountTheme": "keycloak.v3",
  "adminTheme": "keycloak.v2",
  "emailTheme": "keycloak"
}
